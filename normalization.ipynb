    "#normalization\n",
    "arr = np.array([[1,2],[2,4]])\n",
    "mean_=np.mean(arr)\n",
    "std_dev=np.std(arr)\n",
    "\n",
    "normaliztion_arr= (arr- mean_)/std_dev\n",
    "\n",
    "print(normaliztion_arr)\n"
   ]
